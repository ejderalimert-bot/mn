generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Project {
  id          String     @id @default(cuid())
  title       String
  category    String
  status      String
  description String?
  retention   String     @default("0%")
  views       String     @default("0")
  swiped      String     @default("0%")
  stayed      String     @default("0%")
  downloads   String     @default("0")
  team        String     @default("Star Dublaj")
  image       String?
  image2      String?
  coverImage  String?
  coverImage2 String?
  trailer     String?
  focusKeyword String?
  seoTitle    String?
  seoDesc     String?
  slug        String?
  gallery     String     @default("[]") // JSON stringified array
  tags        String     @default("[]") // JSON stringified array of SEO tags
  audioDemos  String     @default("[]") // JSON stringified array of audio URLs
  videoDemos  String     @default("[]") // JSON stringified array of video URLs
  
  progressTranslation String @default("0")
  progressVoice       String @default("0")
  progressMix         String @default("0")
  modLink             String?

  createdAt   DateTime   @default(now())

  // Relations
  comments    Comment[]
  favorites   Favorite[]
  likes       Like[]
}

model Comment {
  id         String   @id @default(cuid())
  text       String
  userId     String
  userName   String
  userAvatar String?
  date       DateTime @default(now())

  projectId  String
  project    Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
}

model Favorite {
  id        String   @id @default(cuid())
  userId    String
  
  projectId String
  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@unique([userId, projectId])
}

model Like {
  id        String   @id @default(cuid())
  userId    String
  
  projectId String
  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@unique([userId, projectId])
}

// NextAuth Tables
model User {
  id            String          @id @default(cuid())
  name          String?
  username      String?         @unique
  email         String?         @unique
  emailVerified DateTime?
  image         String?
  publicFavorites Boolean       @default(true) // Added for privacy setting
  accounts      Account[]
  sessions      Session[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  
  teamMember TeamMember?
  news       News[]

  // Social Relations
  sentMessages     Message[]    @relation("SentMessages")
  receivedMessages Message[]    @relation("ReceivedMessages")
  userFriends      Friendship[] @relation("UserFriends")
  friendUsers      Friendship[] @relation("FriendUsers")
}
 
model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
 
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
 
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
 
  @@unique([provider, providerAccountId])
}
 
model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
 
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
 
model VerificationToken {
  identifier String
  token      String
  expires    DateTime
 
  @@unique([identifier, token])
}

// Analytics Tables
model PageView {
  id        String   @id @default(cuid())
  path      String
  createdAt DateTime @default(now())
}

model ActiveUser {
  id        String   @id
  lastSeen  DateTime @default(now())
}

// Team and News Tables
model TeamMember {
  id        String   @id @default(cuid())
  userId    String   @unique
  roleTitle String   
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
}

model News {
  id          String   @id @default(cuid())
  title       String
  content     String
  image       String?
  video       String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  authorId    String
  author      User     @relation(fields: [authorId], references: [id], onDelete: Cascade)
}

// Social and Messaging Tables
model Message {
  id         String   @id @default(cuid())
  senderId   String
  receiverId String
  content    String
  createdAt  DateTime @default(now())
  
  sender     User     @relation("SentMessages", fields: [senderId], references: [id], onDelete: Cascade)
  receiver   User     @relation("ReceivedMessages", fields: [receiverId], references: [id], onDelete: Cascade)
}

model Friendship {
  id        String   @id @default(cuid())
  userId    String
  friendId  String
  status    String   @default("PENDING") // PENDING, ACCEPTED
  createdAt DateTime @default(now())

  user      User     @relation("UserFriends", fields: [userId], references: [id], onDelete: Cascade)
  friend    User     @relation("FriendUsers", fields: [friendId], references: [id], onDelete: Cascade)

  @@unique([userId, friendId])
}
